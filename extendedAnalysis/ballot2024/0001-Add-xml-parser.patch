+"""
+ADG-xml syntax
+<Scenario>
+    <Defense>: period : int | success_probability : float | name : str | cost : int
+    <AtomicAttacks>: Contains subnodes, each defining an atomic attack
+        <AtomicAttack>: completion_time : int | success_probability : float | activation_cost : int | proportional_cost : int | defenses : List[Defense] | name : str
+    <Subgoal>: children : List[Union[AtomicAttack, Defense, Subgoal]] | operation_type : OperationType | name : str
+    <Maingoal>: str
+"""
+
+def build_from_xml(file: str) -> ADG:
+    """
+    Build an ADG from the given XML file.
+
+    param file: The path to the XML file.
+    return: The built ADG.
+    """
+    defenses = dict()
+    atomic_attacks = dict()
+    subgoals = dict()
+    all_names = dict()
+
+    xml = ET.parse(file)
+
+    scenario = xml.getroot()
+
+    # Init all defenses
+    for defense in scenario.find("Defenses").findall("Defense"):
+        name = defense.get("name")
+        period = int(defense.get("period"))
+        success_probability = float(defense.get("success_probability"))
+        cost = int(defense.get("cost"))
+        if name in defenses or name in all_names:
+            raise ValueError(f"Duplicate name {name} in defenses")
+
+        defenses[name] = Defense(
+            period=period, success_probability=success_probability, name=name, cost=cost
+        )
+        all_names[name] = defenses[name]
+
+    # Init all atomic attacks
+    for atomic_attack in scenario.find("AtomicAttacks").findall("AtomicAttack"):
+        name = atomic_attack.get("name")
+
+        if name in atomic_attacks or name in all_names:
+            raise ValueError(f"Duplicate name {name} in atomic attacks")
+
+        completion_time = int(atomic_attack.get("completion_time"))
+        success_probability = float(atomic_attack.get("success_probability"))
+        activation_cost = int(atomic_attack.get("activation_cost"))
+        proportional_cost = int(atomic_attack.get("proportional_cost"))
+        defense_names = defenses_names = eval(atomic_attack.get("defenses"))
+        defenses_names = [] if defense_names is None else defense_names
+        attack_defenses = []
+        for defense_name in defenses_names:
+            if defense_name not in defenses:
+                raise ValueError(f"Unknown defense {defense_name} in atomic attack {name}")
+            attack_defenses.append(defenses[defense_name])
+
+        atomic_attacks[name] = Attack(
+            completion_time=completion_time,
+            success_probability=success_probability,
+            activation_cost=activation_cost,
+            proportional_cost=proportional_cost,
+            defenses=attack_defenses,
+            name=name,
+        )
+        all_names[name] = atomic_attacks[name]
+
+    # Associate each subgoal name to its XML node, to build them recursively later
+    sg_def = dict()
+    for subgoal in scenario.find("Subgoals").findall("Subgoal"):
+        name = subgoal.get("name")
+        if name in sg_def or name in all_names:
+            raise ValueError(f"Duplicate name {name} in subgoals")
+        sg_def[name] = subgoal
+
+
+    def build_subgoal(sg_name: str) -> Subgoal:
+        """
+        (Recursively) Build the subgoal with the given name.
+
+        param sg_name: The name of the subgoal to build.
+        return: The built subgoal.
+        """
+        if sg_name in all_names:
+            return all_names[sg_name]
+
+        sgd = sg_def[sg_name]
+        children = list(map(build_subgoal, eval(sgd.get("children"))))
+
+        sg = Subgoal(
+            name=sg_name,
+            children=children,
+            operation_type = OperationType.OR if sgd.get("operation_type") == "OR" else OperationType.AND
+        )
+        subgoals[sg_name] = sg
+        all_names[sg_name] = sg
+        return sg
+
+    return ADG(build_subgoal(scenario.find("Maingoal").get("name")))
 
