+def build_adg_very_simple2():
+    # Defenses
+    d_cc = Defense(period=100, success_probability=0.5, name="d_cc", cost=1)
+    d_cp = Defense(period=1000, success_probability=0.75, name="d_cp", cost=10)
+
+    # Atomic attacks
+    a_bf = Attack(
+        completion_time=2,
+        success_probability=0.5,
+        activation_cost=2,
+        proportional_cost=1,
+        defenses=[d_cc],
+        name="a_bf",
+    )
+    a_ss = Attack(
+        completion_time=30,
+        success_probability=0.75,
+        activation_cost=0,
+        proportional_cost=10,
+        defenses=[d_cc],
+        name="a_ss",
+    )
+
+    # Subgoals
+    g_ac = Subgoal(
+        children=[a_bf, a_ss, d_cp], operation_type=OperationType.OR, name="g_ac"
+    )
+    g_0 = Subgoal(children=[g_ac], operation_type=OperationType.AND, name="g_0")
+
+    return ADG(g_0)
+
+def build_adg_super_very_simple():
+    # Defenses
+    d_aa = Defense(period=10, success_probability=0.5, name="d_aa", cost=1)
+
+    # Atomic attacks
+    a_aa = Attack(
+        completion_time=2,
+        success_probability=0.5,
+        activation_cost=2,
+        proportional_cost=1,
+        defenses=[d_aa],
+        name="a_aa",
+    )
+
+    # Subgoals
+    g_sg = Subgoal(
+        children=[a_aa], operation_type=OperationType.OR, name="g_sg"
+    )
+    g_0 = Subgoal(children=[g_sg], operation_type=OperationType.AND, name="g_0")
+
+    return ADG(g_0)
+
